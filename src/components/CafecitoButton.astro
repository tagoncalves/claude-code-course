---
interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;
---

<a
  href="https://cafecito.app/tag-dev"
  target="_blank"
  rel="noopener noreferrer"
  class={`cafecito-btn cafecito-${size}`}
  aria-label="Invitame un café en cafecito.app"
>
  <img
    src="https://cdn.cafecito.app/imgs/buttons/button_6.png"
    srcset="https://cdn.cafecito.app/imgs/buttons/button_6.png 1x,
            https://cdn.cafecito.app/imgs/buttons/button_6_2x.png 2x,
            https://cdn.cafecito.app/imgs/buttons/button_6_3.75x.png 3.75x"
    alt="Invitame un café en cafecito.app"
    loading="lazy"
  />
</a>

<style>
  .cafecito-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    overflow: hidden;
    transition: opacity 0.15s, transform 0.1s;
    text-decoration: none;
  }

  .cafecito-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .cafecito-btn:active {
    transform: scale(0.97);
  }

  .cafecito-btn img {
    display: block;
  }

  .cafecito-sm img {
    height: 32px;
    width: auto;
  }

  .cafecito-md img {
    height: 40px;
    width: auto;
  }
</style>
