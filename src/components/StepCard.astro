---
interface Props {
  stepId: number;
  title: string;
  icon?: string;
}

const { stepId, title, icon = '' } = Astro.props;
---

<section class="step-card step-locked" id={`step-${stepId}`} data-step-id={stepId}>
  <div class="step-header">
    <div class="step-number">{stepId}</div>
    <h2>{icon && <span aria-hidden="true">{icon}</span>} {title}</h2>
    <div class="step-done-badge" aria-label="Completado">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
  </div>
  <div class="step-body">
    <slot />
  </div>
  <div class="step-footer">
    <button class="btn-primary mark-done-btn" data-step={stepId} disabled>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      Marcar como completado
    </button>
  </div>
</section>
