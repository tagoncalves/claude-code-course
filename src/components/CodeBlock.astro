---
import { Code } from 'astro:components';

interface Props {
  code: string;
  lang?: string;
  os?: 'windows' | 'macos' | 'linux';
  label?: string;
}

const { code, lang = 'bash', os, label } = Astro.props;
---

<div class="code-block" data-os={os}>
  <div class="code-header">
    <span class="code-lang">{label || lang}</span>
    <button class="copy-btn" data-code={code} aria-label="Copiar código">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span class="copy-label">Copiar</span>
    </button>
  </div>
  <Code code={code} lang={lang} theme="one-dark-pro" />
</div>
